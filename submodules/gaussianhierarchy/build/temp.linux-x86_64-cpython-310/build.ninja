nvcc = /home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/bin/nvcc

cflags = -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /home/felix-windisch/miniconda3/envs/LodExperiments/include -I/home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/include -L/home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/lib -L/home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/lib/stubs -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /home/felix-windisch/miniconda3/envs/LodExperiments/include -I/home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/include -L/home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/lib -L/home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/lib/stubs -fPIC -I/home/felix-windisch/miniconda3/envs/LodExperiments/lib/python3.10/site-packages/torch/include -I/home/felix-windisch/miniconda3/envs/LodExperiments/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/include -I/home/felix-windisch/miniconda3/envs/LodExperiments/include/python3.10 -c
post_cflags = -I/media/felix-windisch/data/LoDOfGaussians/submodules/gaussianhierarchy/dependencies/eigen/ -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=_C -std=c++17
cuda_cflags = -I/home/felix-windisch/miniconda3/envs/LodExperiments/lib/python3.10/site-packages/torch/include -I/home/felix-windisch/miniconda3/envs/LodExperiments/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/felix-windisch/miniconda3/envs/LodExperiments/targets/x86_64-linux/include -I/home/felix-windisch/miniconda3/envs/LodExperiments/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=_C -gencode=arch=compute_86,code=sm_86 -ccbin /home/felix-windisch/miniconda3/envs/LodExperiments/bin/x86_64-conda-linux-gnu-cc -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







